NODE_ENV=development
# Railway injects PORT at runtime. Keep 8080 as local fallback.
PORT=8080
MONGODB_URI=mongodb://127.0.0.1:27017/convenehub
JWT_ACCESS_SECRET=change-me-access-secret
JWT_REFRESH_SECRET=change-me-refresh-secret
# Allowed frontend origins (comma-separated).
# First origin is also used for OAuth redirects.
FRONTEND_ORIGIN=http://localhost:5173,https://covene-hub.vercel.app

# SMTP (required for OTP email delivery)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-smtp-username
SMTP_PASSWORD=your-smtp-password
SMTP_FROM_EMAIL=no-reply@convenehub.com
OTP_TTL_MINUTES=10

# Google OAuth (required for "Continue with Google")
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:8080/api/v1/auth/google/callback

# Railway backend + Vercel frontend (production)
# NODE_ENV=production
# FRONTEND_ORIGIN=https://covene-hub.vercel.app
# GOOGLE_REDIRECT_URI=https://your-backend-service.up.railway.app/api/v1/auth/google/callback
