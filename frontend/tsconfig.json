{
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "types": ["node"],
    "allowJs": false,
    "skipLibCheck": true,
    "strict": false,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "baseUrl": ".",
    "paths": {
      "@/*": ["./*"],
      "next/link": ["./src/compat/next/link.tsx"],
      "next/image": ["./src/compat/next/image.tsx"],
      "next/navigation": ["./src/compat/next/navigation.ts"],
      "next/dynamic": ["./src/compat/next/dynamic.tsx"],
      "next/script": ["./src/compat/next/script.tsx"],
      "next/font/local": ["./src/compat/next/font-local.ts"],
      "@vercel/analytics/next": ["./src/compat/vercel-analytics-next.tsx"]
    }
  },
  "include": ["src", "app", "components", "hooks", "lib", "types", "utils"],
  "exclude": ["node_modules", "app/api/**", "app/auth/callback/**"]
}
